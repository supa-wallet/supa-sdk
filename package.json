{
  "name": "@supanovaapp/sdk",
  "version": "0.1.0",
  "description": "React SDK for Supa Backend + Privy.io integration with Canton Network support",
  "main": "./dist/index.cjs.js",
  "module": "./dist/index.esm.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.esm.js",
      "require": "./dist/index.cjs.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "vite",
    "build": "tsc -p tsconfig.build.json && vite build",
    "build:prod": "tsc -p tsconfig.build.json && vite build --mode production",
    "preview": "vite preview",
    "type-check": "tsc --noEmit"
  },
  "keywords": [
    "supa",
    "privy",
    "canton",
    "stellar",
    "web3",
    "react",
    "sdk"
  ],
  "author": "npm@supanova.app",
  "license": "MIT",
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0"
  },
  "dependencies": {
    "@headlessui/react": "^2.2.0",
    "@privy-io/react-auth": "^3.3.0",
    "axios": "^1.7.9",
    "buffer": "^6.0.3"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "@types/react": "^19.0.2",
    "@types/react-dom": "^19.0.2",
    "@vitejs/plugin-react": "^5.0.4",
    "typescript": "^5.9.3",
    "vite": "^7.1.11"
  }
}
